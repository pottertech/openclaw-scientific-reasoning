# Environment configuration example for OpenClaw-Scientific-Reasoning
# Copy this to .env and customize for your environment

# Python binary path (default: python3)
# PYTHON_BIN=/usr/local/bin/python3

# Use micromamba environment isolation (0 or 1)
# USE_MAMBA=0

# Micromamba environment name
# ENV_NAME=openclaw-scientific-reasoning

# Installation mode (pip or mamba)
# INSTALL_MODE=pip